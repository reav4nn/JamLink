# Line ending normalization
* text=auto

# Force LF for all source files (Kotlin/C++/TS cross-platform consistency)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.kt text eol=lf
*.java text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.cmake text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jar binary
*.keystore binary
